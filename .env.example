# ── Local PostgreSQL ──────────────────────────────────────────────────────
# The app uses PostgreSQL by default.
# If you don't have PostgreSQL running locally, you can use the embedded
# PostgreSQL from Paperclip (if available) or install PostgreSQL.
#
# DATABASE_URL="postgresql://user:password@host:5432/dbname"
#
# ── Vercel / Production PostgreSQL ────────────────────────────────────────
# 1. Provision PostgreSQL (Neon free tier, Supabase, Vercel Postgres)
# 2. Set DATABASE_URL in Vercel environment variables
# 3. The buildCommand runs prisma migrate deploy automatically
#
# Serverless pooling (Neon/Supabase):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?pgbouncer=true"
# DIRECT_URL="postgresql://user:password@host:5432/dbname"
#
# ── Local SQLite (legacy, for quick dev without PostgreSQL) ───────────────
# To use SQLite: change provider in prisma/schema.prisma to "sqlite",
# then use: DATABASE_URL="file:./dev.db"
#
# ── AI / Vision API ───────────────────────────────────────────────────────
# Required for the multimodal extraction pipeline stage.
# AI_PROVIDER="anthropic"     # or "openai"
# AI_MODEL="claude-sonnet-4-6"  # or "gpt-4o" for OpenAI
# ANTHROPIC_API_KEY="sk-ant-..."
# OPENAI_API_KEY="sk-..."
# AI_MAX_TOKENS="4096"
