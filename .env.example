# ── Local development (SQLite) ──────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ── Production (PostgreSQL) ───────────────────────────────────────────────
# To deploy with data persistence on Vercel:
# 1. Provision PostgreSQL (Neon free tier, Supabase, Vercel Postgres)
# 2. Change provider in prisma/schema.prisma: "sqlite" -> "postgresql"
# 3. Run: npx prisma migrate dev --name init
# 4. Set DATABASE_URL in Vercel environment variables
# 5. Redeploy
#
# PostgreSQL connection string format:
# DATABASE_URL="postgresql://user:password@host:5432/dbname"
#
# Serverless pooling (Neon/Supabase):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?pgbouncer=true"
# DIRECT_URL="postgresql://user:password@host:5432/dbname"
