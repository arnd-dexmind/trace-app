generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserOnboarding {
  id               String   @id @default(cuid())
  userId           String
  tenantId         String
  tourCompleted    Boolean  @default(false)
  tourCurrentStep  Int      @default(0)
  tourDismissed    Boolean  @default(false)
  sampleDataSeeded Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, tenantId])
}

model User {
  id          String       @id @default(cuid())
  clerkId     String       @unique
  email       String?
  name        String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  tenants     UserTenant[]
  sentInvites TeamInvite[]
}

model UserTenant {
  id       String @id @default(cuid())
  userId   String
  tenantId String
  role     String @default("member")
  user     User   @relation(fields: [userId], references: [id])

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
}

model Space {
  id               String            @id @default(cuid())
  tenantId         String
  name             String
  description      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  inventoryItems   InventoryItem[]
  repairIssues     RepairIssue[]
  zones            SpaceZone[]
  storageLocations StorageLocation[]
  walkthroughs     Walkthrough[]

  @@index([tenantId])
}

model Walkthrough {
  id                 String              @id @default(cuid())
  spaceId            String
  tenantId           String
  status             String              @default("uploaded")
  metadata           String?
  uploadedAt         DateTime            @default(now())
  processedAt        DateTime?
  completedAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  itemObservations   ItemObservation[]
  mediaAssets        MediaAsset[]
  processingJobs     ProcessingJob[]
  repairObservations RepairObservation[]
  reviewTasks        ReviewTask?
  shareLinks         ShareLink[]
  space              Space               @relation(fields: [spaceId], references: [id])

  @@index([spaceId, status])
  @@index([tenantId])
}

model MediaAsset {
  id            String      @id @default(cuid())
  walkthroughId String
  tenantId      String
  type          String
  url           String
  thumbnailUrl  String?
  createdAt     DateTime    @default(now())
  walkthrough   Walkthrough @relation(fields: [walkthroughId], references: [id])

  @@index([walkthroughId])
}

model SpaceZone {
  id                  String                @id @default(cuid())
  spaceId             String
  tenantId            String
  name                String
  description         String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  itemLocationHistory ItemLocationHistory[]
  itemObservations    ItemObservation[]
  repairObservations  RepairObservation[]
  space               Space                 @relation(fields: [spaceId], references: [id])
  storageLocations    StorageLocation[]

  @@index([spaceId])
}

model StorageLocation {
  id                  String                @id @default(cuid())
  spaceId             String
  zoneId              String?
  parentId            String?
  tenantId            String
  name                String
  description         String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  itemLocationHistory ItemLocationHistory[]
  itemObservations    ItemObservation[]
  parent              StorageLocation?      @relation("LocationHierarchy", fields: [parentId], references: [id])
  children            StorageLocation[]     @relation("LocationHierarchy")
  space               Space                 @relation(fields: [spaceId], references: [id])
  zone                SpaceZone?            @relation(fields: [zoneId], references: [id])

  @@index([spaceId])
  @@index([zoneId])
  @@index([parentId])
}

model InventoryItem {
  id              String                   @id @default(cuid())
  spaceId         String
  tenantId        String
  name            String
  category        String?
  description     String?
  quantity        Int                      @default(1)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  searchVector    Unsupported("tsvector")? @default(dbgenerated("(setweight(to_tsvector('english'::regconfig, COALESCE(name, ''::text)), 'A'::\"char\") || setweight(to_tsvector('english'::regconfig, COALESCE(description, ''::text)), 'B'::\"char\"))"))
  space           Space                    @relation(fields: [spaceId], references: [id])
  aliases         ItemAlias[]
  identityLinks   ItemIdentityLink[]
  locationHistory ItemLocationHistory[]
  observations    ItemObservation[]
  repairIssues    RepairIssue[]
  reviewActions   ReviewAction[]

  @@index([spaceId, name])
  @@index([tenantId])
}

model ItemAlias {
  id        String        @id @default(cuid())
  itemId    String
  tenantId  String
  alias     String
  source    String        @default("operator")
  createdAt DateTime      @default(now())
  item      InventoryItem @relation(fields: [itemId], references: [id])

  @@unique([itemId, alias])
  @@index([itemId])
  @@index([tenantId])
}

model ItemObservation {
  id                String                @id @default(cuid())
  walkthroughId     String
  tenantId          String
  itemId            String?
  zoneId            String?
  storageLocationId String?
  label             String
  confidence        Float?
  bbox              String?
  keyframeUrl       String?
  status            String                @default("pending")
  createdAt         DateTime              @default(now())
  identityLinks     ItemIdentityLink[]
  locationHistory   ItemLocationHistory[]
  item              InventoryItem?        @relation(fields: [itemId], references: [id])
  storageLocation   StorageLocation?      @relation(fields: [storageLocationId], references: [id])
  walkthrough       Walkthrough           @relation(fields: [walkthroughId], references: [id])
  zone              SpaceZone?            @relation(fields: [zoneId], references: [id])
  reviewActions     ReviewAction[]

  @@index([walkthroughId])
  @@index([itemId])
}

model ItemIdentityLink {
  id              String          @id @default(cuid())
  observationId   String
  itemId          String
  tenantId        String
  matchConfidence Float?
  createdAt       DateTime        @default(now())
  item            InventoryItem   @relation(fields: [itemId], references: [id])
  observation     ItemObservation @relation(fields: [observationId], references: [id])

  @@unique([observationId, itemId])
  @@index([observationId])
  @@index([itemId])
}

model ItemLocationHistory {
  id                  String           @id @default(cuid())
  itemId              String
  tenantId            String
  zoneId              String?
  storageLocationId   String?
  observedAt          DateTime         @default(now())
  sourceObservationId String?
  createdAt           DateTime         @default(now())
  item                InventoryItem    @relation(fields: [itemId], references: [id])
  sourceObservation   ItemObservation? @relation(fields: [sourceObservationId], references: [id])
  storageLocation     StorageLocation? @relation(fields: [storageLocationId], references: [id])
  zone                SpaceZone?       @relation(fields: [zoneId], references: [id])

  @@index([itemId, observedAt])
}

model RepairIssue {
  id                 String              @id @default(cuid())
  spaceId            String
  tenantId           String
  title              String
  description        String?
  severity           String?
  status             String              @default("open")
  itemId             String?
  resolvedAt         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  item               InventoryItem?      @relation(fields: [itemId], references: [id])
  space              Space               @relation(fields: [spaceId], references: [id])
  repairObservations RepairObservation[]

  @@index([spaceId, status])
  @@index([tenantId])
}

model RepairObservation {
  id            String       @id @default(cuid())
  walkthroughId String
  tenantId      String
  repairIssueId String?
  zoneId        String?
  label         String
  confidence    Float?
  bbox          String?
  keyframeUrl   String?
  status        String       @default("pending")
  createdAt     DateTime     @default(now())
  repairIssue   RepairIssue? @relation(fields: [repairIssueId], references: [id])
  walkthrough   Walkthrough  @relation(fields: [walkthroughId], references: [id])
  zone          SpaceZone?   @relation(fields: [zoneId], references: [id])

  @@index([walkthroughId])
  @@index([repairIssueId])
}

model ReviewTask {
  id            String         @id @default(cuid())
  walkthroughId String         @unique
  tenantId      String
  status        String         @default("pending")
  assignedTo    String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  actions       ReviewAction[]
  walkthrough   Walkthrough    @relation(fields: [walkthroughId], references: [id])

  @@index([tenantId, status])
}

model ProcessingJob {
  id            String      @id @default(cuid())
  walkthroughId String
  tenantId      String
  stage         String
  status        String      @default("pending")
  attempt       Int         @default(1)
  maxAttempts   Int         @default(3)
  nextRetryAt   DateTime?
  error         String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime    @default(now())
  walkthrough   Walkthrough @relation(fields: [walkthroughId], references: [id])

  @@index([status, createdAt])
  @@index([walkthroughId])
  @@index([tenantId, status])
}

model ReviewAction {
  id            String           @id @default(cuid())
  reviewTaskId  String
  tenantId      String
  actionType    String
  observationId String?
  itemId        String?
  previousLabel String?
  newLabel      String?
  note          String?
  createdAt     DateTime         @default(now())
  item          InventoryItem?   @relation(fields: [itemId], references: [id])
  observation   ItemObservation? @relation(fields: [observationId], references: [id])
  reviewTask    ReviewTask       @relation(fields: [reviewTaskId], references: [id])

  @@index([reviewTaskId])
}

model ShareLink {
  id            String      @id @default(cuid())
  walkthroughId String
  tenantId      String
  token         String      @unique
  expiresAt     DateTime?
  createdAt     DateTime    @default(now())
  walkthrough   Walkthrough @relation(fields: [walkthroughId], references: [id])

  @@index([walkthroughId])
  @@index([token])
}

model TeamInvite {
  id            String    @id @default(cuid())
  tenantId      String
  inviterUserId String
  email         String
  token         String    @unique
  status        String    @default("pending")
  role          String    @default("member")
  createdAt     DateTime  @default(now())
  acceptedAt    DateTime?
  inviter       User      @relation(fields: [inviterUserId], references: [id])

  @@index([email])
  @@index([tenantId, email, status])
  @@index([tenantId, status])
  @@index([token])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  tenantId  String
  type      String
  title     String
  body      String?
  actionUrl String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([tenantId])
  @@index([userId])
}

model NotificationPreference {
  id                  String   @id @default(cuid())
  userId              String   @unique
  tenantId            String
  inApp               Boolean  @default(true)
  email               Boolean  @default(true)
  walkthroughComplete Boolean  @default(true)
  newIssue            Boolean  @default(true)
  issueResolved       Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model WaitlistEntry {
  id          String    @id @default(cuid())
  name        String
  email       String    @unique
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  ipAddress   String?
  userAgent   String?
  emailSentAt DateTime?
  emailError  String?
  createdAt   DateTime  @default(now())
}
